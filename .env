JIRRABIT_SECRET_KEY=django-insecure--hfi*bj3@3v10yvwos6o+31j*-73!_d573g5ido7vdbqk3_oml
JIRRABIT_ALLOWED_HOSTS=localhost,127.0.0.1
JIRRABIT_DEBUG=1
# Set to 0 when running prod-like locally without a TLS-terminating proxy.
JIRRABIT_SECURE_SSL_REDIRECT=1
JIRRABIT_SECURE_COOKIES=1
JIRRABIT_HSTS_SECONDS=1
JIRRABIT_DB_ENGINE=postgres

# Console backend for local dev — emails print to the web container logs.
# Swap to ``django.core.mail.backends.smtp.EmailBackend`` and fill
# *_HOST/_USER/_PASSWORD when you point at a real SMTP server.
JIRRABIT_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
JIRRABIT_EMAIL_HOST=
JIRRABIT_EMAIL_PORT=587
JIRRABIT_EMAIL_USER=
JIRRABIT_EMAIL_PASSWORD=
JIRRABIT_FROM_EMAIL=jirrabit@localhost


# Postgres
# Option 1: single connection URI (takes precedence if set).
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
JIRRABIT_DATABASE_URI=postgres://jirrabit:jirrabit-local-dev@jirrabit-db:5432/jirrabit

# Option 2: discrete vars (used when JIRRABIT_DATABASE_URI is empty).
POSTGRES_HOST=jirrabit-db
POSTGRES_DB=jirrabit
POSTGRES_USER=jirrabit
POSTGRES_PASSWORD=jirrabit-local-dev


# Redis
REDIS_URL=redis://redis:6379/0